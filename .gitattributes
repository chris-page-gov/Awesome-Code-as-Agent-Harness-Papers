# Keep text files normalized and binary source artifacts out of textual diffs.
* text=auto eol=lf

*.gif binary
*.jpg binary
*.jpeg binary
*.pdf binary
*.png binary

# Localized raw sources are evidence captures, not linted project text.
sources/raw/**/*.html -diff -text whitespace=-blank-at-eol,-blank-at-eof,-space-before-tab
sources/raw/**/*.htm -diff -text whitespace=-blank-at-eol,-blank-at-eof,-space-before-tab
